<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/quizRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── Top Bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#252540"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐"
                android:textSize="15sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Compteur questions -->
        <TextView
            android:id="@+id/tvQuestionCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="#33FFFFFF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="1 / ?"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Switch micro -->
        <Switch
            android:id="@+id/switchMic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="🎙"
            android:textColor="#AAAACC"
            android:textSize="13sp" />

        <!-- Bouton quitter -->
        <ImageButton
            android:id="@+id/btnLogout"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="#3D1F1F"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FF6B6B"
            android:padding="6dp" />
    </LinearLayout>

    <!-- ── Barre de progression ── -->
    <ProgressBar
        android:id="@+id/quizProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/primary_color"
        android:progressBackgroundTint="#252540" />

    <!-- ── Alerte anti-triche ── -->
    <TextView
        android:id="@+id/tvAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B71C1C"
        android:gravity="center"
        android:padding="12dp"
        android:text="⚠️  Alerte de sécurité détectée"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- ── Contenu principal (scrollable) ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="100dp">

            <!-- ── Carte Question ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/questionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#252540"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <ImageView
                        android:id="@+id/ivQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:scaleType="centerInside"
                        android:visibility="gone"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingMultiplier="1.5"
                        android:text="Question..."
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Option A ── -->
            <Button
                android:id="@+id/btnOp1"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#252540"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/badge_background"
                app:iconTint="#6200EE"
                app:iconPadding="12dp" />

            <!-- ── Option B ── -->
            <Button
                android:id="@+id/btnOp2"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#252540"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/badge_background"
                app:iconTint="#2979FF"
                app:iconPadding="12dp" />

            <!-- ── Option C ── -->
            <Button
                android:id="@+id/btnOp3"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="#252540"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/badge_background"
                app:iconTint="#FF6D00"
                app:iconPadding="12dp" />

            <!-- ── Option D ── -->
            <Button
                android:id="@+id/btnOp4"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:backgroundTint="#252540"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:gravity="center_vertical|start"
                android:paddingStart="20dp"
                app:cornerRadius="14dp"
                app:icon="@drawable/badge_background"
                app:iconTint="#00BFA5"
                app:iconPadding="12dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ── Prévisualisation caméra (anti-triche) ── -->
    <androidx.cardview.widget.CardView
        android:layout_width="72dp"
        android:layout_height="96dp"
        android:layout_gravity="end"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="-108dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#252540">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.cardview.widget.CardView>

</LinearLayout>
