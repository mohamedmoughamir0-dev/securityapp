<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Fond -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login"
        android:scaleType="centerCrop" />

    <!-- Overlay sombre -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B0000000" />

    <!-- Contenu -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp"
            android:minHeight="600dp">

            <!-- Badge icône -->
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#252540"
                app:cardElevation="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🔐"
                    android:textSize="34sp" />

            </androidx.cardview.widget.CardView>

            <!-- Titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Créer un compte"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <!-- Sous-titre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="36dp"
                android:text="Rejoignez Quiz Security"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <!-- Carte formulaire -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#CC1A1A2E"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Label Email -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Champ Email -->
                    <EditText
                        android:id="@+id/etEmailRegister"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/edittext_rounded"
                        android:hint="Adresse email"
                        android:inputType="textEmailAddress"
                        android:paddingStart="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#55FFFFFF"
                        android:textSize="15sp" />

                    <!-- Label Mot de passe -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mot de passe"
                        android:textColor="#AAAACC"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <!-- Champ Mot de passe -->
                    <EditText
                        android:id="@+id/etPasswordRegister"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/edittext_rounded"
                        android:hint="Mot de passe (6 caractères min.)"
                        android:inputType="textPassword"
                        android:paddingStart="16dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#55FFFFFF"
                        android:textSize="15sp" />

                    <!-- Indication -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="Minimum 6 caractères"
                        android:textColor="#66FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bouton S'inscrire -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/primary_color"
                android:text="S'INSCRIRE"
                android:textAllCaps="true"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="24dp"
                app:cornerRadius="14dp" />

            <!-- Séparateur -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#33FFFFFF" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="14dp"
                    android:text="ou"
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#33FFFFFF" />
            </LinearLayout>

            <!-- Lien connexion -->
            <TextView
                android:id="@+id/tvToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Déjà un compte ? Se connecter →"
                android:textColor="#BBBBFF"
                android:textStyle="bold"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
